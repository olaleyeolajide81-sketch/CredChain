# Stellar Configuration
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_CONTRACT_ID=
STELLAR_ADMIN_SECRET=
STELLAR_CRED_TOKEN_ADDRESS=

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/credchain
REDIS_URL=redis://localhost:6379

# Backend Configuration
BACKEND_PORT=3001
BACKEND_HOST=localhost
JWT_SECRET=your-jwt-secret-key
API_BASE_URL=http://localhost:3001

# Frontend Configuration
REACT_APP_API_URL=http://localhost:3001
REACT_APP_STELLAR_NETWORK=testnet
REACT_APP_CONTRACT_ID=
REACT_APP_VERSION=1.0.0

# External Services
ORACLE_API_URL=https://api.oracle.example.com
NOTIFICATION_SERVICE_URL=https://notifications.example.com
AUDIT_SERVICE_URL=https://audit.example.com

# Development Configuration
NODE_ENV=development
LOG_LEVEL=debug
ENABLE_CORS=true
ENABLE_MOCK_DATA=false

# Security Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
SESSION_SECRET=your-session-secret
ENCRYPTION_KEY=your-encryption-key

# Monitoring Configuration
SENTRY_DSN=
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Testing Configuration
TEST_STELLAR_NETWORK=testnet
TEST_DATABASE_URL=postgresql://test:test@localhost:5432/credchain_test
ENABLE_TEST_LOGS=false
